  "tipsSquat": "Keep your back straight and look forward.\nSquat down until your thighs are parallel to the floor.\nPush through your heels on the way up.",
  "@tipsSquat": { "description": "Tips for exercise" },
  "tipsFrontSquat": "Keep your elbows as high as possible.\nThe barbell should rest on your front deltoids.\nKeep your torso upright.",
  "@tipsFrontSquat": { "description": "Tips for exercise" },
  "tipsGobletSquat": "Hold the weight close to your chest.\nSquat deep, pushing your knees outward.",
  "@tipsGobletSquat": { "description": "Tips for exercise" },
  "tipsSmithMachineSquat": "Place your feet slightly forward to emphasize the glutes.\nLean back against the bar for support.",
  "@tipsSmithMachineSquat": { "description": "Tips for exercise" },
  "tipsHackSquat": "Keep your back flat against the pad.\nDo not lift your heels off the platform.",
  "@tipsHackSquat": { "description": "Tips for exercise" },
  "tipsLunge": "Take a wide enough step.\nYour back knee should almost touch the floor.\nKeep your front knee behind your toes.",
  "@tipsLunge": { "description": "Tips for exercise" },
  "tipsWalkingLunge": "Maintain balance and do not rush.\nKeep your torso upright.",
  "@tipsWalkingLunge": { "description": "Tips for exercise" },
  "tipsReverseLunge": "Stepping back reduces stress on the knee joints.\nPush off with your front leg to return.",
  "@tipsReverseLunge": { "description": "Tips for exercise" },
  "tipsBulgarianSplitSquat": "Place your rear foot on a bench.\nLean your torso slightly forward to target the glutes.",
  "@tipsBulgarianSplitSquat": { "description": "Tips for exercise" },
  "tipsLegPress": "Do not fully lock your knees at the top of the movement.\nKeep your lower back pressed against the seat.",
  "@tipsLegPress": { "description": "Tips for exercise" },
  "tipsWallSit": "Keep a 90-degree angle at your knees.\nPress your entire back against the wall.",
  "@tipsWallSit": { "description": "Tips for exercise" },
  "tipsLegExtension": "Keep your hips firmly on the seat.\nControl the weight on the way down.",
  "@tipsLegExtension": { "description": "Tips for exercise" },
  "tipsLegCurl": "Perform smooth, controlled movements.\nKeep your hips pressed against the pad.",
  "@tipsLegCurl": { "description": "Tips for exercise" },
  "tipsSeatedLegCurl": "Secure the leg pads firmly.\nCurl your legs as far back as possible.",
  "@tipsSeatedLegCurl": { "description": "Tips for exercise" },
  "tipsDeadlift": "Keep the bar as close to your shins as possible.\nInitiate the lift by pushing with your legs.\nKeep your back perfectly straight.",
  "@tipsDeadlift": { "description": "Tips for exercise" },
  "tipsSumoDeadlift": "Take a very wide stance.\nKeep your torso more upright than in a conventional deadlift.",
  "@tipsSumoDeadlift": { "description": "Tips for exercise" },
  "tipsRomanianDeadlift": "Push your hips back as far as possible.\nKeep a slight bend in your knees.\nFeel the stretch in your hamstrings.",
  "@tipsRomanianDeadlift": { "description": "Tips for exercise" },
  "tipsGoodMorning": "Rest the bar on your traps, similar to a squat.\nHinge at the hips, keeping your legs slightly bent.",
  "@tipsGoodMorning": { "description": "Tips for exercise" },
  "tipsHipThrust": "Rest your shoulder blades on the bench.\nPause at the top and squeeze your glutes.\nTuck your chin to your chest.",
  "@tipsHipThrust": { "description": "Tips for exercise" },
  "tipsGluteBridge": "Drive through your heels.\nDo not hyperextend your lower back at the top.",
  "@tipsGluteBridge": { "description": "Tips for exercise" },
  "tipsCablePullThrough": "Face away from the machine.\nThe movement should come from hinging at the hips.",
  "@tipsCablePullThrough": { "description": "Tips for exercise" },
  "tipsStandingCalfRaise": "Lower your heels as much as possible.\nRaise up on your toes as high as you can.",
  "@tipsStandingCalfRaise": { "description": "Tips for exercise" },
  "tipsSeatedCalfRaise": "Sit up straight and secure the knee pads.\nMove slowly and with control.",
  "@tipsSeatedCalfRaise": { "description": "Tips for exercise" },
  "tipsDonkeyCalfRaise": "Keep your back straight while leaning forward.\nStretch your calves at the bottom of the movement.",
  "@tipsDonkeyCalfRaise": { "description": "Tips for exercise" },
  "tipsAbductorMachine": "Push your legs apart in a smooth motion.\nControl the weight as you bring your legs back.",
  "@tipsAbductorMachine": { "description": "Tips for exercise" },
  "tipsAdductorMachine": "Squeeze your legs together, feeling the inner thighs work.\nKeep your back pressed against the seat.",
  "@tipsAdductorMachine": { "description": "Tips for exercise" },

  "tipsBenchPress": "Retract your shoulder blades and keep them down.\nKeep your feet firmly planted on the floor.\nLower the bar to your nipple line.",
  "@tipsBenchPress": { "description": "Tips for exercise" },
  "tipsInclineBenchPress": "Set the bench angle to 30-45 degrees.\nLower the bar closer to your collarbones.",
  "@tipsInclineBenchPress": { "description": "Tips for exercise" },
  "tipsDeclineBenchPress": "Secure your legs under the pads.\nLower the bar to your lower chest.",
  "@tipsDeclineBenchPress": { "description": "Tips for exercise" },
  "tipsCloseGripBenchPress": "Use a shoulder-width grip or slightly narrower.\nKeep your elbows tucked close to your body.",
  "@tipsCloseGripBenchPress": { "description": "Tips for exercise" },
  "tipsSmithMachineBenchPress": "Adjust the bench so the bar lowers to the middle of your chest.\nControl the descent.",
  "@tipsSmithMachineBenchPress": { "description": "Tips for exercise" },
  "tipsDumbbellBenchPress": "Dumbbells allow for a deeper range of motion.\nBring the dumbbells together at the top, squeezing your chest.",
  "@tipsDumbbellBenchPress": { "description": "Tips for exercise" },
  "tipsInclineDumbbellPress": "Keep your elbows at about a 45-degree angle to your body.\nDo not drop the dumbbells quickly at the bottom.",
  "@tipsInclineDumbbellPress": { "description": "Tips for exercise" },
  "tipsPushUp": "Keep your body in a straight line.\nKeep your elbows tucked at a 45-degree angle.",
  "@tipsPushUp": { "description": "Tips for exercise" },
  "tipsDiamondPushUp": "Form a diamond shape with your index fingers and thumbs.\nLower your chest toward your hands.",
  "@tipsDiamondPushUp": { "description": "Tips for exercise" },
  "tipsWeightedPushUp": "Have a partner place a weight plate on your upper back.\nMaintain perfect form, do not let your lower back sag.",
  "@tipsWeightedPushUp": { "description": "Tips for exercise" },
  "tipsDip": "Lean forward slightly to emphasize the chest.\nDo not go down too deep to protect your shoulders.",
  "@tipsDip": { "description": "Tips for exercise" },
  "tipsMachineFly": "Keep your elbows slightly bent.\nSqueeze your chest muscles as you bring the handles together.",
  "@tipsMachineFly": { "description": "Tips for exercise" },
  "tipsCableCrossover": "Lean forward slightly.\nThe movement should feel like 'hugging a tree'.",
  "@tipsCableCrossover": { "description": "Tips for exercise" },
  "tipsLowCableCrossover": "Pull the handles from the bottom up.\nBring your hands together in front of your upper chest.",
  "@tipsLowCableCrossover": { "description": "Tips for exercise" },
  "tipsDumbbellFly": "Open your arms until you feel a mild stretch in your chest.\nDo not fully lock out your elbows.",
  "@tipsDumbbellFly": { "description": "Tips for exercise" },
  "tipsInclineDumbbellFly": "Set the bench to a 30-degree angle.\nControl the movement, avoiding sudden jerks.",
  "@tipsInclineDumbbellFly": { "description": "Tips for exercise" },
  "tipsPullover": "Lie across or along the bench.\nLower the dumbbell behind your head with slightly bent arms.",
  "@tipsPullover": { "description": "Tips for exercise" },
  "tipsChestPressMachine": "Adjust the seat so the handles are at chest level.\nPress evenly with both arms.",
  "@tipsChestPressMachine": { "description": "Tips for exercise" },

  "tipsPullUp": "Start the pull by bringing your shoulder blades down.\nPull your chest toward the bar, not your chin.\nControl the descent, do not drop your body.",
  "@tipsPullUp": { "description": "Tips for exercise" },
  "tipsChinUp": "Use an underhand grip.\nKeep your elbows close to your body.",
  "@tipsChinUp": { "description": "Tips for exercise" },
  "tipsLatPullDown": "Do not lean back too far.\nPull the bar down to your upper chest.",
  "@tipsLatPullDown": { "description": "Tips for exercise" },
  "tipsCloseGripLatPullDown": "Squeeze your shoulder blades at the bottom.\nUse a narrow grip attachment.",
  "@tipsCloseGripLatPullDown": { "description": "Tips for exercise" },
  "tipsVBarPullDown": "Pull the handle to your solar plexus.\nFeel the maximum contraction of your shoulder blades.",
  "@tipsVBarPullDown": { "description": "Tips for exercise" },
  "tipsBentOverRow": "Lean your torso almost parallel to the floor.\nPull the bar to your waist, not your chest.",
  "@tipsBentOverRow": { "description": "Tips for exercise" },
  "tipsReverseGripRow": "An underhand grip helps keep elbows close to the body.\nControl the weight when lowering the barbell.",
  "@tipsReverseGripRow": { "description": "Tips for exercise" },
  "tipsSingleArmDumbbellRow": "Support yourself with a knee and hand on a bench for stability.\nPull the dumbbell to your hip, not straight up.",
  "@tipsSingleArmDumbbellRow": { "description": "Tips for exercise" },
  "tipsTBarRow": "Maintain a natural arch in your lower back.\nDo not jerk the weight with your torso.",
  "@tipsTBarRow": { "description": "Tips for exercise" },
  "tipsSeatedCableRow": "Sit up straight and avoid leaning back excessively.\nSqueeze your shoulder blades together at the end of the movement.",
  "@tipsSeatedCableRow": { "description": "Tips for exercise" },
  "tipsMachineRow": "Press your chest firmly against the pad.\nFocus on driving your elbows back.",
  "@tipsMachineRow": { "description": "Tips for exercise" },
  "tipsStraightArmPulldown": "Keep your arms slightly bent but locked.\nThe movement should only occur at the shoulder joint.",
  "@tipsStraightArmPulldown": { "description": "Tips for exercise" },
  "tipsHyperextension": "Do not hyperextend your back at the top.\nLower yourself slowly, feeling the stretch.",
  "@tipsHyperextension": { "description": "Tips for exercise" },
  "tipsRackPull": "Set the barbell at knee height.\nPull the weight by extending your hips and back.",
  "@tipsRackPull": { "description": "Tips for exercise" },

  "tipsOverheadPress": "Squeeze your glutes and core to create a rigid base.\nThe bar should travel in a straight line close to your face.",
  "@tipsOverheadPress": { "description": "Tips for exercise" },
  "tipsSeatedDumbbellPress": "Sit on a bench with back support to stabilize your lower back.\nLower the dumbbells to ear level.",
  "@tipsSeatedDumbbellPress": { "description": "Tips for exercise" },
  "tipsSmithMachineShoulderPress": "Adjust the bench so the bar lowers in front of your face.\nDo not fully lock out your elbows at the top.",
  "@tipsSmithMachineShoulderPress": { "description": "Tips for exercise" },
  "tipsArnoldPress": "At the bottom, your palms should face you.\nRotate your wrists as you press the dumbbells up.",
  "@tipsArnoldPress": { "description": "Tips for exercise" },
  "tipsLateralRaise": "Raise your arms as if you are pouring water from pitchers.\nDo not use momentum from your torso.",
  "@tipsLateralRaise": { "description": "Tips for exercise" },
  "tipsCableLateralRaise": "The cable provides constant tension.\nRun the cable behind your back or in front of you.",
  "@tipsCableLateralRaise": { "description": "Tips for exercise" },
  "tipsMachineLateralRaise": "Sit up straight and focus on raising your elbows.\nThe weight should be comfortable enough to maintain good form.",
  "@tipsMachineLateralRaise": { "description": "Tips for exercise" },
  "tipsFrontRaise": "Raise your arms to eye level.\nAvoid swinging your torso.",
  "@tipsFrontRaise": { "description": "Tips for exercise" },
  "tipsCableFrontRaise": "Stand facing away from the machine and run the cable between your legs.\nKeep your elbows slightly bent.",
  "@tipsCableFrontRaise": { "description": "Tips for exercise" },
  "tipsRearDeltRaise": "Lean your torso parallel to the floor.\nFocus on squeezing the rear delts, not just your shoulder blades.",
  "@tipsRearDeltRaise": { "description": "Tips for exercise" },
  "tipsReversePecDeck": "Sit facing the machine.\nKeep your arms parallel to the floor.",
  "@tipsReversePecDeck": { "description": "Tips for exercise" },
  "tipsFacePull": "Pull the rope to eye level.\nExternally rotate your arms at the end of the movement.",
  "@tipsFacePull": { "description": "Tips for exercise" },
  "tipsUprightRow": "Use a shoulder-width or slightly wider grip.\nPull your elbows higher than your hands.",
  "@tipsUprightRow": { "description": "Tips for exercise" },
  "tipsShoulderShrug": "Simply raise your shoulders straight up toward your ears.\nDo not roll your shoulders.",
  "@tipsShoulderShrug": { "description": "Tips for exercise" },

  "tipsBicepsCurl": "Keep your elbows tucked into your sides.\nAvoid swinging your torso.",
  "@tipsBicepsCurl": { "description": "Tips for exercise" },
  "tipsDumbbellCurl": "You can perform this alternating arms.\nRotate your wrist (supinate) during the curl.",
  "@tipsDumbbellCurl": { "description": "Tips for exercise" },
  "tipsHammerCurl": "Hold the dumbbells with a neutral grip (palms facing each other).\nThe movement should be smooth and controlled.",
  "@tipsHammerCurl": { "description": "Tips for exercise" },
  "tipsPreacherCurl": "Press your triceps firmly against the pad.\nDo not fully extend your arms to protect your joints.",
  "@tipsPreacherCurl": { "description": "Tips for exercise" },
  "tipsConcentrationCurl": "Rest your elbow on the inner part of your thigh.\nDo not use your shoulder or torso to assist.",
  "@tipsConcentrationCurl": { "description": "Tips for exercise" },
  "tipsCableCurl": "The cable creates constant tension in the muscle.\nTake a step back from the machine to increase the range of motion.",
  "@tipsCableCurl": { "description": "Tips for exercise" },
  "tipsZottmanCurl": "Curl the dumbbells with an underhand grip (palms up).\nLower the dumbbells with an overhand grip (palms down).",
  "@tipsZottmanCurl": { "description": "Tips for exercise" },
  "tipsTricepsExtension": "Can be performed with one or two hands.\nYour elbows should point straight up.",
  "@tipsTricepsExtension": { "description": "Tips for exercise" },
  "tipsSkullCrusher": "Lower the bar behind your head or to your forehead.\nYour elbows should not flare out to the sides.",
  "@tipsSkullCrusher": { "description": "Tips for exercise" },
  "tipsTricepPushdown": "Only your forearms should move.\nFully extend your arms at the bottom.",
  "@tipsTricepPushdown": { "description": "Tips for exercise" },
  "tipsRopePushdown": "Pull the ends of the rope apart at the bottom.\nKeep your torso leaned slightly forward.",
  "@tipsRopePushdown": { "description": "Tips for exercise" },
  "tipsOverheadCableExtension": "Stand facing away from the cable machine.\nFully stretch the triceps by letting the rope go deep behind your head.",
  "@tipsOverheadCableExtension": { "description": "Tips for exercise" },
  "tipsTricepDipMachine": "Sit up straight and press your back against the pad.\nPress the handles until your arms are fully extended.",
  "@tipsTricepDipMachine": { "description": "Tips for exercise" },
  "tipsBenchDip": "Keep your hips as close to the bench as possible.\nLower yourself until your elbows are at a 90-degree angle.",
  "@tipsBenchDip": { "description": "Tips for exercise" },

  "tipsCrunch": "Do not lift your lower back off the floor.\nCrunch by bringing your ribs closer to your pelvis.",
  "@tipsCrunch": { "description": "Tips for exercise" },
  "tipsCableCrunch": "Kneel facing away from the machine.\nCrunch using your abs, do not pull with your arms.",
  "@tipsCableCrunch": { "description": "Tips for exercise" },
  "tipsSitUp": "You can anchor your feet.\nLift your entire torso until your chest touches your knees.",
  "@tipsSitUp": { "description": "Tips for exercise" },
  "tipsLegRaise": "Press your lower back into the floor.\nLower your legs slowly without letting your heels touch the ground.",
  "@tipsLegRaise": { "description": "Tips for exercise" },
  "tipsLegRaiseHang": "Avoid swinging your body.\nTry to tilt your pelvis upward at the top of the movement.",
  "@tipsLegRaiseHang": { "description": "Tips for exercise" },
  "tipsRussianTwist": "Keep your back straight and lean back slightly.\nRotate your shoulders, not just your arms.",
  "@tipsRussianTwist": { "description": "Tips for exercise" },
  "tipsPlank": "Your body should form a straight line from head to heels.\nDo not lift your hips or let your lower back sag.",
  "@tipsPlank": { "description": "Tips for exercise" },
  "tipsSidePlank": "Your elbow should be directly under your shoulder.\nDo not let your hips sag.",
  "@tipsSidePlank": { "description": "Tips for exercise" },
  "tipsAbWheelRollout": "Keep your back slightly rounded and abs tight.\nDo not arch your lower back when fully extended.",
  "@tipsAbWheelRollout": { "description": "Tips for exercise" },
  "tipsBicycleCrunch": "Bring your right elbow to your left knee and vice versa.\nKeep your mouth open and breathe evenly.",
  "@tipsBicycleCrunch": { "description": "Tips for exercise" },
  "tipsWoodchopper": "Pull the cable diagonally from top to bottom.\nLock your hips and rotate only your upper torso.",
  "@tipsWoodchopper": { "description": "Tips for exercise" },

  "tipsCardioTreadmill": "Maintain good posture and do not slouch.\nTo increase intensity, raise the incline rather than just the speed.",
  "@tipsCardioTreadmill": { "description": "Tips for exercise" },
  "tipsCardioElliptical": "Use the handles to actively engage your upper body.\nKeep your heels on the pedals.",
  "@tipsCardioElliptical": { "description": "Tips for exercise" },
  "tipsCardioRowing": "The movement consists of a leg drive followed by an arm pull.\nKeep your back straight throughout the movement.",
  "@tipsCardioRowing": { "description": "Tips for exercise" },
  "tipsFarmerWalk": "Keep your back perfectly straight and shoulders back.\nTake short, quick steps.",
  "@tipsFarmerWalk": { "description": "Tips for exercise" },
  "tipsKettlebellSwing": "The momentum comes entirely from your hips (a hinge movement).\nDo not lift the kettlebell with your arms or shoulders.",
  "@tipsKettlebellSwing": { "description": "Tips for exercise" }
}